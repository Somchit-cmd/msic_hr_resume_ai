generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  name       String
  password   String
  role       String      @default("hr")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  templates  JDTemplate[]
  aiSettings AISettings?
}

model Candidate {
  id                String   @id @default(cuid())
  fileName          String
  filePath          String
  jobDescription    String
  candidateOverview String
  scoring           Int
  assessment        String
  professionalAudit String   // JSON string: { pros: string[], cons: string[], red_flags: string[] }
  recommendation    String
  extractedText     String?  // Store extracted resume text for reference
  status            String   @default("completed") // completed, processing, error
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model JDTemplate {
  id              String   @id @default(cuid())
  name            String   // Template name, e.g. "Senior Frontend Engineer"
  jobTitle        String
  department      String   @default("")
  employmentType  String   @default("")
  experienceLevel String   @default("")
  location        String   @default("")
  salaryRange     String   @default("")
  requiredSkills  String   @default("[]") // JSON array string
  preferredSkills String   @default("[]") // JSON array string
  education       String   @default("")
  responsibilities String  @default("")
  additionalNotes String   @default("")
  usageCount      Int      @default(0)
  userId          String?  // null = global/default template
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AISettings {
  id          String   @id @default(cuid())
  provider    String   @default("z-ai")     // z-ai, openai, anthropic, google, custom
  model       String   @default("default")  // model name/identifier
  apiKey      String?  // API key for external providers (stored encrypted-like, but plain for now)
  baseUrl     String?  // custom base URL for OpenAI-compatible endpoints
  temperature Float    @default(0.7)
  maxTokens   Int      @default(4096)
  userId      String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
