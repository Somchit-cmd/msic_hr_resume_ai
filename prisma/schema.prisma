generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("hr")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Candidate {
  id                String   @id @default(cuid())
  fileName          String
  filePath          String
  jobDescription    String
  candidateOverview String
  scoring           Int
  assessment        String
  professionalAudit String   // JSON string: { pros: string[], cons: string[], red_flags: string[] }
  recommendation    String
  extractedText     String?  // Store extracted resume text for reference
  status            String   @default("completed") // completed, processing, error
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
